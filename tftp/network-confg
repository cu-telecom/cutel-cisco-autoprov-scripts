version 15.1
!
username bootstrap privilege 15 password 0 bootstrap
!
hostname bootstrap
ip domain name example.org
!
line vty 0 4
 privilege level 15
 transport input all
 login local
!
event manager applet BOOTSTRAP-AUTOPROV
 event syslog pattern "SYS-5-RESTART" maxrun 300000
 action 0.0 cli command "enable"
 action 0.1 cli command "terminal length 0"
 action 0.2 syslog msg "Downloading tcl library"
 action 0.3 cli command "archive tar /xtract http://100.64.0.1:8080/library.tar library"
 action 0.4 syslog msg "Running setup-autoprov.tcl"
 action 0.5 cli command "tclsh library/setup-autoprov.tcl"
 ! The applet will only get this far if setup-autoprov fails
 action 0.6 cli command "configure terminal"
 action 0.7 cli command "event manager applet BOOTSTRAP-AUTOPROV"
 action 0.8 cli command "event timer watchdog time 300 maxrun 300000"
 action 0.9 cli command "end"
end